{
  "name": "tor-landa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "depcheck": "depcruise src --config .dependency-cruiser.mjs --output-type text",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm knip && pnpm depcheck && pnpm build",
    "test:telegram": "node -r dotenv/config scripts/test-telegram.js dotenv_config_path=.env.local"
  },
  "dependencies": {
    "@notionhq/client": "^4.0.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dependency-cruiser": "^18.1.0",
    "knip": "^6.27.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
